{
  "name": "@takeyaqa/pict-wasm",
  "version": "3.7.4-wasm.17",
  "description": "Unofficial WebAssembly build of Microsoft's PICT",
  "keywords": [
    "pict",
    "testing",
    "testing-tools",
    "test-case-generation",
    "combinatorial-testing",
    "pairwise",
    "pairwise-testing",
    "webassembly"
  ],
  "homepage": "https://github.com/takeyaqa/pict-wasm#readme",
  "bugs": {
    "url": "https://github.com/takeyaqa/pict-wasm/issues"
  },
  "license": "MIT",
  "author": "Takeshi Kishi",
  "contributors": [
    "Microsoft Corporation"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/takeyaqa/pict-wasm.git"
  },
  "scripts": {
    "build": "make wasm && tsc",
    "clean": "make wasm-clean",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:node": "vitest --project node",
    "test:browser": "vitest --project browser"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/node22": "^22.0.5",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": "^22 || ^24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^22"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "^10"
      }
    ]
  }
}
